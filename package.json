{
  "name": "ddd-monorepo",
  "private": true,
  "scripts": {
    "install:admin": "pnpm --filter @ddd/admin install",
    "install:web": "pnpm --filter @ddd/web install",
    "dev:admin": "pnpm --filter @ddd/admin dev",
    "dev:web": "pnpm --filter @ddd/web dev",
    "build:admin": "pnpm --filter @ddd/admin build",
    "build:web": "pnpm --filter @ddd/web build",
    "storybook": "pnpm --filter @ddd/ui storybook",
    "test:ui": "pnpm --filter @ddd/ui test",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
