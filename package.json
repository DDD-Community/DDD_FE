{
  "name": "ddd-monorepo",
  "private": true,
  "scripts": {
    "dev:admin": "pnpm --filter @ddd/admin dev",
    "dev:web":   "pnpm --filter @ddd/web dev",
    "build:admin": "pnpm --filter @ddd/admin build",
    "db:generate": "pnpm --filter @ddd/db db:generate",
    "db:migrate":  "pnpm --filter @ddd/db db:migrate",
    "db:push":     "pnpm --filter @ddd/db db:push",
    "db:studio":   "pnpm --filter @ddd/db db:studio"
  },
  "engines": { "node": ">=20", "pnpm": ">=9" }
}
