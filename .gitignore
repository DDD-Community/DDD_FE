# Monorepo root ignore rules

# dependencies
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
**/coverage/

# next.js
**/.next/
**/out/

# build outputs
**/build/
**/dist/

# Orval generated code (백엔드 스펙 동기화 전까지 gitignore)
packages/api/src/generated/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
**/.vercel/

# typescript
*.tsbuildinfo
**/next-env.d.ts

# IDE
.idea/
.vscode/
*.swp
*.swo


# omc
.omc/

# agent
.agent/
.agents/
# .claude/

# playwright-mcp screenshots / snapshots
.playwright-mcp/
**/.playwright-mcp/
/*.png
/*.jpg
/*.jpeg

#docs/*
!docs/hero-ui.txt